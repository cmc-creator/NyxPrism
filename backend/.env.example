# ── PostgreSQL — Railway provides DATABASE_URL automatically ──────────
DATABASE_URL=postgresql://postgres:password@host.railway.internal:5432/railway

# ── Stripe ────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_MONTHLY=price_...
STRIPE_PRICE_ID_ANNUAL=price_...

# ── Resend (email delivery) ───────────────────────────────────────────
RESEND_API_KEY=re_...
CONTACT_EMAIL=info@nyxprism.com

# ── Firebase Admin SDK ────────────────────────────────────────────────
# Get these from Firebase Console → Project Settings → Service Accounts
# → Generate new private key → download JSON → copy values below
FIREBASE_PROJECT_ID=nyxprism-2a817
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@nyxprism-2a817.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ── App ───────────────────────────────────────────────────────────────
FRONTEND_URL=https://nyxprism.com
PORT=3000
